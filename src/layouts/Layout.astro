---
import { websiteSchema } from "../schemas/website.ts";
import Footer from "../components/Footer.astro";
import NavBar from "../components/NavBar.astro";
import "../styles/global.css";
import { personSchema } from "../schemas/person";
const currentLang = Astro.currentLocale || "es";
---

<!doctype html>
<html lang={currentLang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/jpeg" href="profile.jpg" />
		<meta name="generator" content={Astro.generator} />

		<title>Yoan Santiago | MERN Stack Developer | Frontend & Backend</title>
		<meta
			name="description"
			content="Passionate frontend developer creating exceptional web experiences using React, JavaScript, and modern frameworks for responsive applications"
		/>

		<meta property="og:title" content="Yoan Santiago | MERN Stack Developer | Frontend & Backend" />
		<meta
			property="og:description"
			content="Passionate frontend developer creating exceptional web experiences using React, JavaScript, and modern frameworks for responsive applications"
		/>
		<meta property="og:image" content="https://santiagodev.dev/profile.jpg" />
		<meta property="og:url" content="https://santiagodev.com" />
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content="Yoan Santiago | MERN Stack Developer | Frontend & Backend" />
		<meta
			name="twitter:description"
			content="Passionate frontend developer creating exceptional web experiences using React, JavaScript, and modern frameworks for responsive applications"
		/>
		<meta name="twitter:image" content="https://santiagodev.dev/profile.jpg" />
		<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
		<script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
	</head>
	<body class="relative text-zinc-800 dark:text-zinc-100 flex flex-col gap-8 md:gap-16">
		<NavBar />
		<div
			class="fixed inset-0 -z-20 min-h-screen w-full [background:radial-gradient(125%_125%_at_50%_10%,#fafafa_60%,#7f00b2_140%)] dark:[background:radial-gradient(125%_125%_at_50%_10%,#0d0d0d_60%,#7f00b2_140%)]"
		>
		</div>
		<slot />
		<Footer />
	</body>
</html>

<style>
	html,
	body {
		color-scheme: dark ligth;
		font-family: "Jost", sans-serif;
		margin: 0;
		width: 100%;
		height: 100%;
		scroll-behavior: smooth;
	}
</style>
