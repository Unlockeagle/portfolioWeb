---
import type { languageList } from "../i18n/ui";
import { useTranslations } from "../i18n/utils";
import { educationData } from "../i18n/ui";
import SectionComponent from "./SectionComponent.astro";

const currentLang = (Astro.currentLocale || 'es') as keyof typeof educationData;
const translateLabels = useTranslations(currentLang as keyof typeof languageList)
const courses = educationData[currentLang] ?? educationData['es'];
---

<SectionComponent id="formacion" title={translateLabels('nav.education')} icon={true}>
    {courses.map((course, index) => (
        <details class="education-detail" name="requirements" open={index === 0}>
            <summary class="education-summary">{course.title}</summary>
            <ul>
                {course.items.map(item => <li>{item}</li>)}
            </ul>
        </details>
    ))}
</SectionComponent>

<style>
    @reference "tailwindcss";
    
    /* Estilo base para details */
    .education-detail {
        @apply p-2 md:p-4 backdrop-blur-md bg-zinc-50/5 hover:bg-zinc-200/10 rounded-md border border-zinc-800/50 dark:border-zinc-100/20 transition-all ease-in-out duration-300;
        cursor: pointer;
        overflow: hidden;
    }
    
    .education-detail:hover {
        @apply border-zinc-800/80 dark:border-zinc-100/80;
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
    }
    
    /* Estilo para el summary con animación del indicador */
    .education-summary {
        @apply list-none text-xl relative pl-8 py-2 transition-all duration-300;
        cursor: pointer;
    }
    
    /* Indicador personalizado (flecha) */
    .education-summary::before {
        content: "▶";
        position: absolute;
        left: 0;
        top: 50%;
        transform: translateY(-50%);
        transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        color: rgb(168 85 247); /* purple-500 */
        font-size: 0.8em;
    }
    
    /* Flecha rotada cuando está abierto */
    .education-detail[open] .education-summary::before {
        transform: translateY(-50%) rotate(90deg);
    }
    
    /* Hover effect en el summary */
    .education-summary:hover {
        @apply text-purple-400;
        padding-left: 2.5rem;
    }
    
    /* Animación del contenido */
    .education-detail > ul {
        @apply list-disc text-lg flex-col pl-6 backdrop-blur-md rounded-md py-2;
        animation: fadeInDown 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        transform-origin: top;
    }
    
    /* Keyframes para la animación de contenido */
    @keyframes fadeInDown {
        from {
            opacity: 0;
            transform: translateY(-10px) scaleY(0.95);
        }
        to {
            opacity: 1;
            transform: translateY(0) scaleY(1);
        }
    }
    
    /* Transición suave cuando se cierra */
    .education-detail:not([open]) {
        max-height: auto;
    }
    
    /* Efecto adicional para elementos de lista */
    .education-detail > ul > li {
        @apply transition-all duration-200;
        animation: slideInLeft 0.3s ease-out;
        animation-fill-mode: both;
    }
    
    /* Delay escalonado para los elementos de lista */
    .education-detail > ul > li:nth-child(1) { animation-delay: 0.1s; }
    .education-detail > ul > li:nth-child(2) { animation-delay: 0.15s; }
    .education-detail > ul > li:nth-child(3) { animation-delay: 0.2s; }
    .education-detail > ul > li:nth-child(4) { animation-delay: 0.25s; }
    .education-detail > ul > li:nth-child(5) { animation-delay: 0.3s; }
    .education-detail > ul > li:nth-child(6) { animation-delay: 0.35s; }
    .education-detail > ul > li:nth-child(7) { animation-delay: 0.4s; }
    .education-detail > ul > li:nth-child(8) { animation-delay: 0.45s; }
    .education-detail > ul > li:nth-child(9) { animation-delay: 0.5s; }
    .education-detail > ul > li:nth-child(10) { animation-delay: 0.55s; }
    .education-detail > ul > li:nth-child(11) { animation-delay: 0.6s; }
    .education-detail > ul > li:nth-child(12) { animation-delay: 0.65s; }
    .education-detail > ul > li:nth-child(13) { animation-delay: 0.7s; }
    .education-detail > ul > li:nth-child(14) { animation-delay: 0.75s; }
    
    @keyframes slideInLeft {
        from {
            opacity: 0;
            transform: translateX(-20px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }
    
    /* Efecto hover en los items de lista */
    .education-detail > ul > li:hover {
        @apply text-purple-300;
        transform: translateX(5px);
        padding-left: 0.5rem;
    }
</style>
