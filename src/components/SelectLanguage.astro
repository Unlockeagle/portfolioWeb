---
const currentLang = Astro.currentLocale || "es";
const currentPath = Astro.url.pathname;

function generateLanguageUrl(lang: string, currentPath: string): string {
  const pathWithoutLang = currentPath.replace(/^\/(es|en|it)(\/.*)?$/, '$2') || '/';
  if (lang === 'es') return pathWithoutLang;
  return `/${lang}${pathWithoutLang}`;
}

const esUrl = generateLanguageUrl('es', currentPath);
const enUrl = generateLanguageUrl('en', currentPath);
const itUrl = generateLanguageUrl('it', currentPath);

const languages = [
  { code: 'es', label: 'ES', flag: '🇪🇸', name: 'Español', url: esUrl },
  { code: 'en', label: 'EN', flag: '🇬🇧', name: 'English', url: enUrl },
  { code: 'it', label: 'IT', flag: '🇮🇹', name: 'Italiano', url: itUrl },
];

const current = languages.find(l => l.code === currentLang) ?? languages[0];
---

<div class="lang-dropdown" id="lang-dropdown">
  <button
    class="lang-trigger"
    aria-haspopup="listbox"
    aria-expanded="false"
    aria-label="Select language"
    id="lang-trigger"
  >
    <!-- Globe icon -->
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="globe-icon" aria-hidden="true">
      <circle cx="12" cy="12" r="10"/>
      <path d="M2 12h20"/>
      <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
    </svg>
    <span class="trigger-label">
      <!-- <span class="trigger-flag">{current.flag}</span> -->
      <span>{current.label}</span>
    </span>
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="chevron-icon" aria-hidden="true">
      <path d="M6 9l6 6 6-6"/>
    </svg>
  </button>

  <ul class="lang-menu" role="listbox" aria-label="Languages" id="lang-menu">
    {languages.map(({ code, label, flag, name, url }) => (
      <li role="option" aria-selected={currentLang === code}>
        <a
          href={url}
          class={`lang-option ${currentLang === code ? 'lang-option--active' : ''}`}
        >
          {/* <span class="option-flag">{flag}</span> */}
          <span class="option-name">{name}</span>
          <span class="option-code">{label}</span>
          {currentLang === code && (
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="check-icon" aria-hidden="true">
              <path d="M20 6L9 17l-5-5"/>
            </svg>
          )}
        </a>
      </li>
    ))}
  </ul>
</div>

<style>
  .lang-dropdown {
    position: relative;
    display: inline-block;
  }

  .lang-trigger {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: rgb(216 180 254); /* purple-200 */
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    backdrop-filter: blur(8px);
    transition: background 0.2s, border-color 0.2s, color 0.2s;
    letter-spacing: 0.03em;
  }

  .lang-trigger:hover,
  .lang-dropdown.open .lang-trigger {
    background: rgba(168, 85, 247, 0.2);
    border-color: rgba(168, 85, 247, 0.5);
    color: white;
  }

  .globe-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    opacity: 0.85;
  }

  .trigger-label {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .trigger-flag {
    font-size: 1rem;
    line-height: 1;
  }

  .chevron-icon {
    width: 12px;
    height: 12px;
    flex-shrink: 0;
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 0.7;
  }

  .lang-dropdown.open .chevron-icon {
    transform: rotate(180deg);
  }

  .lang-menu {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    min-width: 160px;
    background: rgba(18, 10, 30, 0.92);
    border: 1px solid rgba(168, 85, 247, 0.25);
    border-radius: 12px;
    padding: 6px;
    list-style: none;
    margin: 0;
    backdrop-filter: blur(16px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(168, 85, 247, 0.1);
    opacity: 0;
    transform: translateY(-6px) scale(0.97);
    pointer-events: none;
    transition: opacity 0.2s cubic-bezier(0.4, 0, 0.2, 1), transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    transform-origin: top right;
    z-index: 50;
  }

  .lang-dropdown.open .lang-menu {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  .lang-option {
    display: flex;
    align-items: center;
	margin-top: 4px;
    gap: 8px;
    padding: 8px 10px;
    border-radius: 8px;
    text-decoration: none;
    color: rgb(196 181 253);
    font-size: 0.85rem;
    transition: background 0.15s, color 0.15s;
  }

  .lang-option:hover {
    background: rgba(168, 85, 247, 0.2);
    color: white;
  }

  .lang-option--active {
    background: rgba(126, 34, 206, 0.35);
    color: white;
  }

  .option-flag {
    font-size: 1.1rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .option-name {
    flex: 1;
    font-weight: 500;
  }

  .option-code {
    font-size: 0.7rem;
    font-weight: 700;
    opacity: 0.5;
    letter-spacing: 0.06em;
  }

  .check-icon {
    width: 13px;
    height: 13px;
    color: rgb(168 85 247);
    flex-shrink: 0;
    margin-left: auto;
  }
</style>

<script>
  const dropdown = document.getElementById('lang-dropdown');
  const trigger = document.getElementById('lang-trigger');
  const menu = document.getElementById('lang-menu');

  trigger?.addEventListener('click', () => {
    const isOpen = dropdown?.classList.toggle('open');
    trigger.setAttribute('aria-expanded', String(isOpen));
  });

  document.addEventListener('click', (e) => {
    if (!dropdown?.contains(e.target as Node)) {
      dropdown?.classList.remove('open');
      trigger?.setAttribute('aria-expanded', 'false');
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      dropdown?.classList.remove('open');
      trigger?.setAttribute('aria-expanded', 'false');
      trigger?.focus();
    }
  });
</script>